# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual env
.venv/

# Local env vars (never commit)
.env

# IDE
.idea/

# OS
.DS_Store
Thumbs.db

# Local run outputs
runs/

# Generated plots
# NOTE: we commit plots under figures/ so they render in GitHub README.
# Keep ignoring other stray PNGs in the repo root if any.
!figures/
!figures/**
# If you still want to ignore arbitrary pngs elsewhere, keep the global rule.
# But do NOT ignore figures/*.png.
*.png
!figures/**/*.png
